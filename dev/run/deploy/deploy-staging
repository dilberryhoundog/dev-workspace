#!/bin/bash
### Pull from remote and deploy staging application
# Optionally refreshes staging database from production
# Deploy using kamal staging destination

set -e

SERVER="root@46.224.112.91"
PROD_DB="/var/lib/docker/volumes/bizzy_storage/_data/production.sqlite3"
STAGING_DB="/var/lib/docker/volumes/bizzy_staging_storage/_data/production.sqlite3"

git switch staging

echo ""
echo "── Deploy to staging ──"
echo ""

echo "→ Pulling latest staging changes..."
git pull origin staging

read -p "→ Refresh staging database from production? [y/N] " answer
if [[ "$answer" =~ ^[Yy]$ ]]; then
  echo "→ Copying production database to staging..."
  ssh "$SERVER" "sqlite3_rsync $PROD_DB $STAGING_DB"
  echo "→ Database refreshed."
fi

echo "→ Deploying to staging..."
kamal deploy -d staging

echo ""
echo "✓ Staging deployed at staging.bizzy.grahams.coffee"
echo ""
