{
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git checkout:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git -C :* diff:*)",
      "Bash(git -C :* show:*)",
      "Bash(git -C :* log:*)",
      "Bash(git -C :* ls-files:*)",
      "Bash(git -C :* status:*)",
      "Bash(gh issue:*)",
      "Bash(gh label create:*)",
      "Bash(gh label list:*)",
      "Bash(rails:*)",
      "Bash(bundle:*)",
      "Bash(rake:*)",
      "Bash(dev-workspace:*)",
      "Skill(dev-workspace)",
      "Skill(openclaw-docs)",
      "Skill(conversation-capture)",
      "Skill(magic-reply)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./config/master.key)",
      "Read(./config/credentials/**)",
      "Read(./config/credentials.yml.enc)",
      "Read(./**/*secret*)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Edit(./.env)",
      "Edit(./config/master.key)",
      "Edit(./.git/config)",
      "Edit(./Gemfile.lock)",
      "Edit(./package-lock.json)",
      "Edit(./db/schema.rb)"
    ],
    "ask": [
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh issue edit:*)",
      "Bash(gh issue comment:*)",
      "Bash(rails db:*)",
      "Bash(bundle install:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "dev-workspace"
          },
          {
            "type": "command",
            "command": "dev-workspace tree"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "dev-workspace tree"
          }
        ]
      }
    ]
  },
  "outputStyle": "default",
  "plansDirectory": "./dev/workspace/plans",
  "sandbox": {
    "enabled": false,
    "autoAllowBashIfSandboxed": true,
    "excludedCommands": [
      "git"
    ],
    "allowUnsandboxedCommands": false,
    "network": {
      "allowLocalBinding": true
    }
  }
}
