#!/usr/bin/env ruby

require 'json'
require 'erb'
require 'ostruct'
require 'pathname'
require 'date'
require 'fileutils'
require 'yaml'

class ConversationCapture
  CLAUDE_DIR = File.join(Dir.home, '.claude')

  # Config lives in the per-workspace file, scoped to one section.
  WORKSPACE_CONFIG = File.join('dev', 'workspace', 'workspace-config.yml')
  CONFIG_SECTION = 'conversation_capture'

  # Distinct exit codes for the two guard failures (SKILL.md handles recovery).
  EXIT_NO_CONFIG = 3
  EXIT_NO_SECTION = 4

  attr_reader :session_id, :config, :templates_dir

  def initialize(session_id, config_path: nil)
    @session_id = session_id
    @templates_dir = File.expand_path('../templates', __dir__)
    @config_file = config_path || File.join(Dir.pwd, WORKSPACE_CONFIG)
    @config = load_config
  end

  def run
    jsonl_path = find_jsonl
    unless jsonl_path
      $stderr.puts "JSONL not found for session: #{session_id}"
      exit 1
    end

    lines = read_jsonl(jsonl_path)
    metadata = extract_metadata(lines)
    output_file = resolve_output_file(metadata)

    write_header(output_file, metadata)
    parse_conversation(output_file, lines)
    sanitize(output_file)

    puts output_file
  end

  private

  # --- Config ---

  def load_config
    unless File.exist?(@config_file)
      $stderr.puts "conversation-capture: no workspace config at #{@config_file}"
      exit EXIT_NO_CONFIG
    end

    data = YAML.load_file(@config_file) || {}
    section = data[CONFIG_SECTION]
    unless section.is_a?(Hash)
      $stderr.puts "conversation-capture: missing '#{CONFIG_SECTION}' section in #{@config_file}"
      exit EXIT_NO_SECTION
    end
    section
  end

  # --- JSONL Discovery ---

  def find_jsonl
    project_hash = derive_project_hash(Dir.pwd)
    path = File.join(CLAUDE_DIR, 'projects', project_hash, "#{session_id}.jsonl")
    File.exist?(path) ? path : nil
  end

  def derive_project_hash(cwd)
    cwd.gsub('/', '-')
  end

  # --- JSONL Parsing (ported from extract_transcript.rb) ---

  def read_jsonl(path)
    File.readlines(path).filter_map do |line|
      JSON.parse(line.strip, symbolize_names: true) if line.strip.length > 0
    end
  end

  def extract_metadata(lines)
    first_user = lines.find { |line| line[:type] == 'user' } || {}
    {
      session_id: first_user[:sessionId] || session_id,
      timestamp: format_timestamp(first_user[:timestamp]),
      git_branch: first_user[:gitBranch] || 'unknown',
      cwd: first_user[:cwd] || Dir.pwd
    }
  end

  def format_timestamp(ts)
    return 'unknown' unless ts
    DateTime.parse(ts).strftime('%Y-%m-%d %H:%M')
  rescue
    'unknown'
  end

  # --- Output File ---

  def resolve_output_file(metadata)
    output_dir = File.join(Dir.pwd, config.fetch('output_dir', 'dev/workspace/history'))
    FileUtils.mkdir_p(output_dir)

    prefix = session_id[0, 8]
    existing = Dir.glob(File.join(output_dir, "#{prefix}_*")).first

    if existing
      existing
    else
      File.join(output_dir, "#{prefix}_#{session_id}.txt")
    end
  end

  # --- Template Rendering (ported from extract_transcript.rb) ---

  def deep_ostruct(obj)
    case obj
    when Hash
      OpenStruct.new(obj.transform_values { |v| deep_ostruct(v) })
    when Array
      obj.map { |v| deep_ostruct(v) }
    else
      obj
    end
  end

  def render_template(template_name, data)
    template_path = File.join(templates_dir, template_name)
    template_content = File.read(template_path)
    context = deep_ostruct(data)
    ERB.new(template_content, trim_mode: '-').result(context.instance_eval { binding })
  end

  def write_header(output_file, metadata)
    File.open(output_file, 'w') do |f|
      f.write render_template('header.txt', metadata)
    end
  end

  def parse_conversation(output_file, lines)
    File.open(output_file, 'a') do |f|
      lines.each do |line|
        _template, rendered = format_line(line)
        next unless rendered
        f.write(rendered)
      end
    end
  end

  def format_line(line)
    template = case line
    # Skip metadata types
    in { type: 'file-history-snapshot' | 'queue-operation' | 'summary' }
      nil

    # User Agent - Agent result from Task
    in { type: 'user', toolUseResult: { agentId: String, status: 'completed' } }
      return [nil, nil] unless config.fetch('include_subagents', false)
      'user_agent_result.txt'

    # User Agent - Agent result from Background Task
    in { type: 'user', toolUseResult: { retrieval_status: 'success' } }
      return [nil, nil] unless config.fetch('include_subagents', false)
      'user_agent_background_result.txt'

    # User message - array content (filter tool_results)
    in { type: 'user', message: { content: [{ type: 'tool_result' }] } }
      nil

    # User message - slash command
    in { type: 'user', message: { content: msg } } if msg.include?('<command-name>')
      'user_message_slash_command.txt'

    # Ignore system generated user messages
    in { type: 'user', message: { content: msg } } if msg.include?('<local-command-stdout>') || msg.include?('Caveat: The messages below were generated by the user while running local commands.')
      nil

    # User message - string content
    in { type: 'user', message: { content: String } }
      'user_message.txt'

    # Assistant - has text content
    in { type: 'assistant', message: { content: [{ text: String }] } }
      'assistant_message.txt'

    # Assistant - Bash tool
    in { type: 'assistant', message: { content: [{ name: 'Bash' }] } }
      'assistant_tool_bash.txt'

    # Assistant - Skill tool
    in { type: 'assistant', message: { content: [{ name: 'Skill' }] } }
      'assistant_tool_skill.txt'

    # Assistant - Agent/Task tool
    in { type: 'assistant', message: { content: [{ name: 'Task' }] } }
      'assistant_tool_task.txt'

    # Assistant - Thinking
    in { type: 'assistant', message: { content: [{ type: 'thinking' }] } }
      return [nil, nil] unless config.fetch('include_thinking', false)
      'assistant_thinking.txt'

    # Assistant - Read, Write, Edit
    in { type: 'assistant', message: { content: [{ name: name }] } } if %w[Write Read Edit].include?(name)
      'assistant_tool_read&write.txt'

    else
      nil
    end

    return [nil, nil] unless template
    [template, render_template(template, line)]
  end

  # --- Sanitize ---

  def sanitize(output_file)
    patterns = config.fetch('sanitize', nil)
    return unless patterns.is_a?(Array) && !patterns.empty?

    content = File.read(output_file)

    patterns.each do |pattern|
      find = expand_env(pattern['find'].to_s)
      replace = expand_env(pattern['replace'].to_s)
      next if find.empty?
      content.gsub!(find, replace)
    end

    File.write(output_file, content)
  end

  def expand_env(str)
    str.gsub(/\$([A-Z_][A-Z0-9_]*)/i) { ENV[$1] || $& }
  end

end

# --- CLI ---

if __FILE__ == $0
  session_id = nil
  config_path = nil

  args = ARGV.dup
  while arg = args.shift
    case arg
    when '--config'
      config_path = args.shift
    else
      session_id = arg
    end
  end

  unless session_id
    $stderr.puts "Usage: conversation-capture <session_id> [--config <path>]"
    exit 1
  end

  ConversationCapture.new(session_id, config_path: config_path).run
end
