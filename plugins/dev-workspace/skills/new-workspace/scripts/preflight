#!/bin/bash

### Gathers branch and repo state for new-workspace skill.
# Outputs JSON for Claude to reason about.
# Usage: preflight <branch-name>

set -e

BRANCH_NAME="$1"

if [[ -z "$BRANCH_NAME" ]]; then
    echo '{"error": "missing_branch_name"}'
    exit 1
fi

# Current branch
CURRENT_BRANCH=$(git branch --show-current)

# Parent branch validation
PARENT_VALID=false
if [[ "$CURRENT_BRANCH" == "main" || "$CURRENT_BRANCH" == "command" ]]; then
    PARENT_VALID=true
fi

# Remote detection
ACTUAL_REMOTE=$(git config --get "branch.$CURRENT_BRANCH.remote" 2>/dev/null || echo "")
if [[ "$CURRENT_BRANCH" == "main" ]]; then
    EXPECTED_REMOTE="origin"
else
    EXPECTED_REMOTE="fork"
fi

REMOTE_STATUS="ok"
REMOTE="$ACTUAL_REMOTE"

if [[ -z "$ACTUAL_REMOTE" ]]; then
    REMOTE_STATUS="no_upstream"
    REMOTE="$EXPECTED_REMOTE"
elif [[ "$ACTUAL_REMOTE" != "$EXPECTED_REMOTE" ]]; then
    REMOTE_STATUS="unexpected_remote"
fi

# Working tree
WORKING_TREE_CLEAN=true
if [[ -n $(git status --porcelain) ]]; then
    WORKING_TREE_CLEAN=false
fi

# Fetch and sync status
AHEAD=0
BEHIND=0
FETCH_OK=false

if git fetch "$REMOTE" "$CURRENT_BRANCH" 2>/dev/null; then
    FETCH_OK=true
    UPSTREAM="$REMOTE/$CURRENT_BRANCH"
    AHEAD=$(git rev-list --count "$UPSTREAM"..HEAD)
    BEHIND=$(git rev-list --count HEAD.."$UPSTREAM")
fi

# Local branches (stripped of leading whitespace and * marker, JSON-escaped)
LOCAL_BRANCHES="["
FIRST=true
while IFS= read -r branch; do
    branch=$(echo "$branch" | sed 's/^[* ]*//' | sed 's/\\/\\\\/g; s/"/\\"/g')
    if [[ "$FIRST" == true ]]; then
        FIRST=false
    else
        LOCAL_BRANCHES+=","
    fi
    LOCAL_BRANCHES+="\"$branch\""
done < <(git branch --list)
LOCAL_BRANCHES+="]"

# Output JSON
cat <<EOF
{
  "branch_name": "$BRANCH_NAME",
  "current_branch": "$CURRENT_BRANCH",
  "parent_valid": $PARENT_VALID,
  "remote": "$REMOTE",
  "expected_remote": "$EXPECTED_REMOTE",
  "actual_remote": "$ACTUAL_REMOTE",
  "remote_status": "$REMOTE_STATUS",
  "working_tree_clean": $WORKING_TREE_CLEAN,
  "fetch_ok": $FETCH_OK,
  "ahead": $AHEAD,
  "behind": $BEHIND,
  "local_branches": $LOCAL_BRANCHES
}
EOF
