#!/bin/bash

### Creates a new branch from a parent branch.
# No interactive prompts — caller is responsible for validation.
# Usage: create-branch <branch-name> <parent-branch>

set -e

BRANCH_NAME="$1"
PARENT_BRANCH="$2"

if [[ -z "$BRANCH_NAME" || -z "$PARENT_BRANCH" ]]; then
    echo "error: usage: create-branch <branch-name> <parent-branch>"
    exit 1
fi

git checkout -b "$BRANCH_NAME" --no-track "$PARENT_BRANCH"
echo "created: $BRANCH_NAME from $PARENT_BRANCH"
