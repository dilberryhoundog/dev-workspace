#!/bin/bash
# Finds and runs the project-local dev-workspace skill script.
SCRIPT_PATH=".claude/skills/dev-workspace/scripts/dev-workspace"

dir="$PWD"
while [[ "$dir" != "/" ]]; do
    if [[ -f "$dir/$SCRIPT_PATH" ]]; then
        exec "$dir/$SCRIPT_PATH" "$@"
    fi
    dir="$(dirname "$dir")"
done
echo "❌ Not in a dev-workspace project"
exit 1
