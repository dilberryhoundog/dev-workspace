#!/bin/bash

# cleanup-claude-code.sh — Detect Claude Code conversation exports
# Called by: dev-workspace cleanup claude-code
# Args: $1 = project root, $2 = workspace history path

set -e

PROJECT_ROOT="$1"
HISTORY_DIR="$2"

if [[ -z "$PROJECT_ROOT" || -z "$HISTORY_DIR" ]]; then
    echo "❌ Usage: cleanup-claude-code.sh <project_root> <history_dir>"
    exit 1
fi

# Claude Code exports match: YYYY-MM-DD-HHMMSS-<slug>.txt
EXPORT_PATTERN='[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]-[0-9][0-9][0-9][0-9][0-9][0-9]-*.txt'

# Find exports in project root
export_count=0
export_files=()

for f in "$PROJECT_ROOT"/$EXPORT_PATTERN; do
    [[ -f "$f" ]] || continue
    export_files+=("$f")
    ((export_count++))
done

if [[ $export_count -eq 0 ]]; then
    echo "No Claude Code exports found in project root."
    exit 1
fi

# List exports
echo "EXPORTS:"
for f in "${export_files[@]}"; do
    local_name=$(basename "$f")
    lines=$(wc -l < "$f" | tr -d ' ')
    echo "  $local_name ($lines lines)"
done

echo ""

# List existing history files
history_count=0
echo "HISTORY:"
if [[ -d "$HISTORY_DIR" ]]; then
    for f in "$HISTORY_DIR"/*.txt; do
        [[ -f "$f" ]] || continue
        local_name=$(basename "$f")
        lines=$(wc -l < "$f" | tr -d ' ')
        echo "  $local_name ($lines lines)"
        ((history_count++))
    done
fi

if [[ $history_count -eq 0 ]]; then
    echo "  (empty)"
fi

echo ""
echo "FOUND: $export_count export(s), $history_count history file(s)"
echo ""
echo "Read references/cleanup.md for processing instructions."
