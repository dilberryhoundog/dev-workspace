#!/bin/bash
# dev-deploy — Deployment pipeline automation
#
# Usage: dev-deploy <command> [flags]
# Config: dev/deploy/deploy-config.yml

set -e

CONFIG_FILE="dev/deploy/deploy-config.yml"

# Resolve skill directory (.../skills/dev-deploy — holds scripts, references,
# and templates/deploy-config.yml + templates/hooks/ which are copied once).
resolve_skill_dir() {
    local scripts_dir
    scripts_dir=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
    echo "$(dirname "$scripts_dir")"
}

SKILL_DIR=$(resolve_skill_dir)
# Plugin root is two levels up (.../plugins/dev-deploy). Its templates/ dir is the
# project-mirroring scaffold (.claude/) refreshed into a deploy repo on init.
PLUGIN_ROOT=$(cd "$SKILL_DIR/../.." && pwd)
SCAFFOLD_DIR="$PLUGIN_ROOT/templates"

# Single source of truth for the version: plugin.json. Avoids drift between the
# manifest and this script. Falls back to "unknown" if the manifest is missing
# or unreadable.
resolve_version() {
    local manifest="$PLUGIN_ROOT/.claude-plugin/plugin.json"
    [ -f "$manifest" ] || { echo "unknown"; return; }
    local v
    v=$(grep -m1 '"version"' "$manifest" | sed -E 's/.*"version"[[:space:]]*:[[:space:]]*"([^"]*)".*/\1/')
    echo "${v:-unknown}"
}
VERSION=$(resolve_version)

# ==============================================================================
# YAML PARSER (shared with dev-workspace)
# ==============================================================================

_yaml_walk() {
    local file="$1"
    IFS='.' read -ra parts <<< "$2"

    local depth=0
    local target="${parts[$depth]}"
    local max_depth=$(( ${#parts[@]} - 1 ))
    local found=false
    local target_indent=-1

    while IFS= read -r line; do
        # Skip blank lines and comments
        [[ -z "$line" || "$line" =~ ^[[:space:]]*# ]] && {
            [[ "$found" == true ]] && echo "$line"
            continue
        }

        # Calculate indent (number of leading spaces)
        local stripped="${line#"${line%%[![:space:]]*}"}"
        local indent=$(( ${#line} - ${#stripped} ))

        # If we've found our target and hit same/lower indent, we're done
        if [[ "$found" == true && "$indent" -le "$target_indent" ]]; then
            break
        fi

        if [[ "$found" == true ]]; then
            echo "$line"
            continue
        fi

        # Match current target at expected indent level
        local expected_indent=$(( depth * 2 ))
        if [[ "$indent" -eq "$expected_indent" || ("$indent" -ge "$expected_indent" && "$depth" -gt 0) ]]; then
            local key_part="${stripped%%:*}"
            key_part="${key_part%% *}"
            if [[ "$key_part" == "$target" ]]; then
                if [[ "$depth" -eq "$max_depth" ]]; then
                    # Found final key — check for inline value
                    local value="${stripped#*: }"
                    if [[ "$value" != "$stripped" && "$value" != *":" ]]; then
                        # Inline value (not just "key:")
                        echo "$line"
                    fi
                    found=true
                    target_indent=$indent
                else
                    # Descend to next level
                    (( depth++ ))
                    target="${parts[$depth]}"
                fi
            fi
        fi
    done < "$file"

    [[ "$found" == true ]]
}

yaml_get() {
    local file="$1" key="$2"
    [[ ! -f "$file" ]] && return 1

    local output
    output=$(_yaml_walk "$file" "$key") || return 1

    # Extract scalar value from first line
    echo "$output" | head -1 | sed 's/^[^:]*: *//' | sed 's/ *#.*//' | sed 's/^["'\'']\(.*\)["'\'']$/\1/'
}

yaml_get_array() {
    local file="$1" key="$2"
    [[ ! -f "$file" ]] && return 1

    _yaml_walk "$file" "$key" | grep -E '^ *- ' | sed 's/^ *- *//' | sed 's/^["'\'']\(.*\)["'\'']$/\1/'
}

yaml_section_exists() {
    local file="$1" key="$2"
    [[ ! -f "$file" ]] && return 1

    _yaml_walk "$file" "$key" >/dev/null 2>&1
}

# ==============================================================================
# CONFIG LOADING
# ==============================================================================

CONFIG=""
PROJECT_ROOT=""

find_project_root() {
    local dir="$PWD"
    while [[ "$dir" != "/" ]]; do
        if [[ -f "$dir/$CONFIG_FILE" ]]; then
            echo "$dir"
            return 0
        fi
        dir=$(dirname "$dir")
    done
    return 1
}

load_config() {
    PROJECT_ROOT=$(find_project_root) || {
        echo "❌ No deploy-config.yml found"
        echo "   Expected at: $CONFIG_FILE"
        echo "   Run: dev-deploy init"
        exit 1
    }
    CONFIG="$PROJECT_ROOT/$CONFIG_FILE"

    # Source
    SOURCE_BRANCH=$(yaml_get "$CONFIG" "source.branch") || SOURCE_BRANCH=""

    # Staging
    STAGING_BRANCH=$(yaml_get "$CONFIG" "staging.branch") || STAGING_BRANCH=""
    STAGING_KAMAL_DEST=$(yaml_get "$CONFIG" "staging.kamal_destination") || STAGING_KAMAL_DEST=""
    STAGING_URL=$(yaml_get "$CONFIG" "staging.url") || STAGING_URL=""
    STAGING_MERGE_STRATEGY=$(yaml_get "$CONFIG" "staging.merge_strategy") || STAGING_MERGE_STRATEGY="--no-edit"

    # Production
    PROD_BRANCH=$(yaml_get "$CONFIG" "production.branch") || PROD_BRANCH=""
    PROD_URL=$(yaml_get "$CONFIG" "production.url") || PROD_URL=""
    PROD_PROMOTE_FROM=$(yaml_get "$CONFIG" "production.promote_from") || PROD_PROMOTE_FROM=""
    PROD_MERGE_STRATEGY=$(yaml_get "$CONFIG" "production.merge_strategy") || PROD_MERGE_STRATEGY="--no-edit"
    PROD_KAMAL_DEST=$(yaml_get "$CONFIG" "production.kamal_destination") || PROD_KAMAL_DEST=""

    # Server
    SERVER_HOST=$(yaml_get "$CONFIG" "server.host") || SERVER_HOST=""
    SERVER_PORT=$(yaml_get "$CONFIG" "server.port") || SERVER_PORT="22"

    # Hooks
    HOOK_BACKUP_DB=$(yaml_get "$CONFIG" "hooks.backup_db") || HOOK_BACKUP_DB=""
    HOOK_REFRESH_DB=$(yaml_get "$CONFIG" "hooks.refresh_db") || HOOK_REFRESH_DB=""
    HOOK_PRE_DEPLOY=$(yaml_get "$CONFIG" "hooks.pre_deploy") || HOOK_PRE_DEPLOY=""
    HOOK_POST_DEPLOY=$(yaml_get "$CONFIG" "hooks.post_deploy") || HOOK_POST_DEPLOY=""
    HOOK_HEALTH=$(yaml_get "$CONFIG" "hooks.health") || HOOK_HEALTH=""
}

# ==============================================================================
# GIT MERGE-STATE HELPERS
# ==============================================================================

# True when git is mid-merge (conflict paused). Git's MERGE_HEAD is the source
# of truth — no custom state file needed to detect this.
is_merging() {
    [[ -f "$(git rev-parse --git-dir)/MERGE_HEAD" ]]
}

# Guard for --continue: refuse unless a merge is in progress with all
# conflicts resolved.
require_merging() {
    if ! is_merging; then
        echo "❌ No merge in progress"
        echo "   --continue is for completing a merge after resolving conflicts"
        exit 1
    fi
    if git diff --name-only --diff-filter=U 2>/dev/null | grep -q .; then
        echo "❌ Unresolved conflicts remain"
        echo "   Resolve all conflicts (git status), then re-run --continue"
        exit 1
    fi
}

# ==============================================================================
# HOOK RUNNER
# ==============================================================================

run_hook() {
    local hook_name="$1"
    local hook_path="$2"
    local deploy_env="${3:-}"

    if [[ -z "$hook_path" ]]; then
        return 0
    fi

    local full_path="$PROJECT_ROOT/$hook_path"
    if [[ ! -f "$full_path" ]]; then
        echo "⚠ Hook not found: $hook_path"
        echo "  Skipping $hook_name"
        return 1
    fi

    if [[ ! -x "$full_path" ]]; then
        chmod +x "$full_path"
    fi

    echo ""
    echo "🪝 Running hook: $hook_name ($hook_path)"

    # Set branch and URL based on environment
    local branch url
    if [[ "$deploy_env" == "production" ]]; then
        branch="$PROD_BRANCH"
        url="$PROD_URL"
    else
        branch="$STAGING_BRANCH"
        url="$STAGING_URL"
    fi

    DEPLOY_ENV="$deploy_env" \
    DEPLOY_SERVER_HOST="$SERVER_HOST" \
    DEPLOY_SERVER_PORT="$SERVER_PORT" \
    DEPLOY_BRANCH="$branch" \
    DEPLOY_URL="$url" \
    "$full_path"
}

# ==============================================================================
# HELP
# ==============================================================================

cmd_help() {
    local topic="${1:-}"
    case "$topic" in
        init)
            echo "dev-deploy init — Scaffold deploy config and hooks"
            echo ""
            echo "Usage:"
            echo "  dev-deploy init                Scaffold deploy-config.yml (into dev/deploy/) + templates"
            echo "  dev-deploy init --hooks        Also scaffold example hook scripts into dev/deploy/hooks/"
            echo "  dev-deploy init --update       Deliver plugin changes to a branch"
            echo "  dev-deploy init --check        Verify config is valid (source, staging, production, hooks, Kamal)"
            echo ""
            echo "The init process:"
            echo "  1. Run 'init' to create deploy-config.yml"
            echo "  2. Edit deploy-config.yml for your project (branches, server, URLs)"
            echo "  3. Run 'init --hooks' to scaffold example hook scripts (optional)"
            echo "  4. Edit hooks for your server/database setup"
            echo "  5. Run 'init --check' to verify everything is wired up"
            ;;
        stage)
            echo "dev-deploy stage — Merge source into staging branch"
            echo ""
            echo "Usage:"
            echo "  dev-deploy stage               Merge source → staging and push"
            echo "  dev-deploy stage --check       Preflight — verify readiness before staging"
            echo "  dev-deploy stage --continue    Complete staging after resolving conflicts"
            echo ""
            echo "Preflight (--check) reports:"
            echo "  • Is source branch in sync with origin?"
            echo "  • How many commits will be merged into staging?"
            echo "  • Current staging branch status"
            echo ""
            echo "The source branch (source.branch in config) must be in sync with"
            echo "origin before staging can proceed. If not in sync, the command"
            echo "fails — push or pull your source branch first."
            echo ""
            echo "If the merge hits conflicts, the command stops on the staging branch."
            echo "Resolve the conflicts, then run 'dev-deploy stage --continue' to finish"
            echo "the merge commit and push. You stay on the staging branch."
            echo ""
            echo "Merge strategy: staging.merge_strategy (default: --no-edit)."
            echo "  --squash is not supported here — stage a squash manually with git."
            ;;
        deploy)
            echo "dev-deploy deploy — Deploy via Kamal"
            echo ""
            echo "Usage:"
            echo "  dev-deploy deploy staging               Deploy staging environment"
            echo "  dev-deploy deploy staging --check        Show what would be deployed"
            echo "  dev-deploy deploy staging --refresh-db   Refresh staging DB before deploying"
            echo "  dev-deploy deploy production             Promote and deploy production"
            echo "  dev-deploy deploy production --check     Show production deploy plan"
            echo ""
            echo "Staging deploy:"
            echo "  Switches to staging branch, pulls latest, runs hooks, deploys via Kamal."
            echo "  --refresh-db runs the refresh_db hook before deploying."
            echo ""
            echo "Production deploy:"
            echo "  1. Pulls promote_from branch (usually staging)"
            echo "  2. Merges into production branch and pushes"
            echo "  3. Runs backup_db hook (database backup)"
            echo "  4. Runs pre_deploy hook"
            echo "  5. Deploys via Kamal"
            echo "  6. Runs post_deploy hook"
            echo "  7. Switches back to promote_from branch"
            ;;
        boot)
            echo "dev-deploy boot — Start application via Kamal"
            echo ""
            echo "Usage:"
            echo "  dev-deploy boot                 Boot production (default)"
            echo "  dev-deploy boot staging          Boot staging environment"
            echo "  dev-deploy boot production       Boot production environment"
            echo ""
            echo "Runs: kamal app boot [-d <kamal_destination>]"
            echo "Kamal destination is read from config."
            ;;
        stop)
            echo "dev-deploy stop — Stop application via Kamal"
            echo ""
            echo "Usage:"
            echo "  dev-deploy stop                 Stop production (default)"
            echo "  dev-deploy stop staging          Stop staging environment"
            echo "  dev-deploy stop production       Stop production environment"
            echo ""
            echo "Runs: kamal app stop [-d <kamal_destination>]"
            echo "Kamal destination is read from config."
            ;;
        setup)
            echo "dev-deploy setup — Run setup operations via hooks"
            echo ""
            echo "Usage:"
            echo "  dev-deploy setup --refresh-db   Refresh staging DB from production (runs refresh_db hook)"
            echo "  dev-deploy setup --check         Show configured hooks and server details"
            echo ""
            echo "Hooks receive config as environment variables (DEPLOY_SERVER_HOST, DEPLOY_ENV, etc)."
            echo "Scaffold example hooks with: dev-deploy init --hooks"
            echo "Configure hook paths in deploy-config.yml under 'hooks' section."
            ;;
        health)
            echo "dev-deploy health — Health check for apps, branches, and server"
            echo ""
            echo "Usage:"
            echo "  dev-deploy health               Run full health check"
            echo ""
            echo "Checks:"
            echo "  Source    — Is source branch in sync with origin?"
            echo "  Staging  — Staging sync with origin, source merge status"
            echo "  Apps     — Kamal container status (up/down + uptime)"
            echo "  Server   — Custom health hook, or basic disk check via SSH"
            echo ""
            echo "Custom server checks: configure hooks.health in deploy-config.yml."
            ;;
        *)
            echo "dev-deploy — Deployment pipeline automation"
            echo ""
            echo "Usage: dev-deploy <command> [options]"
            echo "       dev-deploy help <command>   Show command details"
            echo ""
            echo "Commands:"
            echo "  init              Scaffold deploy config and hooks"
            echo "  stage             Merge source into staging"
            echo "  deploy            Deploy via Kamal (staging or production)"
            echo "  boot              Start application via Kamal"
            echo "  stop              Stop application via Kamal"
            echo "  setup             Run setup operations (DB refresh etc)"
            echo "  health            Health check (apps, branches, server)"
            echo "  help              Show this help"
            echo ""
            echo "Global options:"
            echo "  --check           Inspect state without making changes"
            echo ""
            echo "Config: $CONFIG_FILE"
            echo "Hooks:  dev/deploy/hooks/"
            ;;
    esac
}

# ==============================================================================
# INIT
# ==============================================================================

cmd_init() {
    case "${1:-}" in
        --check)
            init_check
            ;;
        --hooks)
            init_scaffold
            init_hooks
            ;;
        --update)
            init_update
            ;;
        "")
            init_scaffold
            ;;
        *)
            cmd_help init
            ;;
    esac
}

init_scaffold() {
    # Project root: an existing config up-tree wins, else CWD (first-time setup).
    local project_root
    project_root=$(find_project_root 2>/dev/null) || project_root="$PWD"

    local target_dir="$project_root/dev/deploy"
    local config_target="$target_dir/deploy-config.yml"

    local config_template="$SKILL_DIR/templates/deploy-config.yml"
    if [[ ! -f "$config_template" ]]; then
        echo "❌ Config template not found: $config_template"
        exit 1
    fi

    mkdir -p "$target_dir"

    # 1. Config — copy once, never clobber (user-edited).
    if [[ -f "$config_target" ]]; then
        echo "ℹ deploy-config.yml already exists (kept)"
    else
        cp "$config_template" "$config_target"
        echo "✓ Created $config_target"
    fi

    # 2. Scaffold mirror (.claude/) — additive, never clobber.
    if [[ -d "$SCAFFOLD_DIR" ]]; then
        rsync -a --ignore-existing "$SCAFFOLD_DIR"/ "$project_root"/
        echo "✓ Scaffold applied (new files only)"
    fi

    echo ""
    echo "═══════════════════════════════════════"
    echo "  ✓ Config scaffolded"
    echo "═══════════════════════════════════════"
    echo ""
    echo "Next steps:"
    echo "  1. Edit $config_target for your project"
    echo "     (set source branch, staging/production branches, server, hooks)"
    echo "  2. Run: dev-deploy init --hooks   (optional — scaffold example hook scripts)"
    echo "  3. Run: dev-deploy init --check   (verify config)"
}

# Refresh the plugin-delivered scaffold (.claude rules) into the deploy repo,
# overwriting changed files but preserving everything not in the templates
# (no --delete). deploy-config.yml and dev/deploy/hooks/ are skill-owned and
# live outside the mirror, so they are never touched. No branch gate — a deploy
# repo's .claude is static across branches.
init_update() {
    if [[ ! -d "$SCAFFOLD_DIR" ]]; then
        echo "ℹ No scaffold templates to refresh ($SCAFFOLD_DIR)"
        return 0
    fi

    local project_root
    project_root=$(find_project_root 2>/dev/null) || project_root="$PWD"

    echo ""
    echo "🔄 Refreshing scaffold from plugin templates..."
    rsync -a "$SCAFFOLD_DIR"/ "$project_root"/
    echo "✓ Scaffold refreshed (deploy-config.yml and hooks left untouched)"

    echo ""
    echo "═══════════════════════════════════════"
    echo "  ✓ Scaffold updated"
    echo "═══════════════════════════════════════"
}

init_hooks() {
    local project_root
    project_root=$(find_project_root 2>/dev/null) || project_root="$PWD"
    local hooks_dir="$project_root/dev/deploy/hooks"
    local template_dir="$SKILL_DIR/templates/hooks"

    mkdir -p "$hooks_dir"

    local count=0
    for hook_template in "$template_dir"/*; do
        [[ -f "$hook_template" ]] || continue
        local hook_name
        hook_name=$(basename "$hook_template")
        local hook_target="$hooks_dir/$hook_name"

        if [[ -f "$hook_target" ]]; then
            echo "ℹ $hook_name already exists"
        else
            cp "$hook_template" "$hook_target"
            chmod +x "$hook_target"
            echo "✓ Created $hook_target"
            count=$((count + 1))
        fi
    done

    echo ""
    echo "✓ $count hook template(s) scaffolded in $hooks_dir"
    echo "  Edit hooks for your project's server and database setup"
}

init_check() {
    load_config

    echo "🔍 Checking deploy config..."
    echo ""

    local issues=0

    # Source
    if [[ -n "$SOURCE_BRANCH" ]]; then
        echo "✓ Source branch: $SOURCE_BRANCH"
    else
        echo "⚠ source.branch not set"
        issues=$((issues + 1))
    fi

    # Staging
    if yaml_section_exists "$CONFIG" "staging"; then
        echo "✓ Staging: $STAGING_BRANCH"
        [[ -n "$STAGING_KAMAL_DEST" ]] && echo "  Kamal destination: $STAGING_KAMAL_DEST"
        [[ -n "$STAGING_URL" ]] && echo "  URL: $STAGING_URL"
    else
        echo "ℹ Staging: not configured (disabled)"
    fi

    # Production
    if yaml_section_exists "$CONFIG" "production"; then
        echo "✓ Production: $PROD_BRANCH"
        echo "  Promote from: $PROD_PROMOTE_FROM"
        [[ -n "$PROD_KAMAL_DEST" ]] && echo "  Kamal destination: $PROD_KAMAL_DEST"
        [[ -n "$PROD_URL" ]] && echo "  URL: $PROD_URL"
    else
        echo "⚠ production section not configured"
        issues=$((issues + 1))
    fi

    # Server
    if [[ -n "$SERVER_HOST" ]]; then
        echo "✓ Server: $SERVER_HOST:$SERVER_PORT"
    else
        echo "ℹ Server: not configured (hooks won't have SSH details)"
    fi

    # Hooks
    echo ""
    echo "Hooks:"
    for hook_var in HOOK_BACKUP_DB HOOK_REFRESH_DB HOOK_PRE_DEPLOY HOOK_POST_DEPLOY HOOK_HEALTH; do
        local hook_val="${!hook_var}"
        local hook_label="${hook_var#HOOK_}"
        hook_label=$(echo "$hook_label" | tr '[:upper:]' '[:lower:]')
        if [[ -n "$hook_val" ]]; then
            if [[ -f "$PROJECT_ROOT/$hook_val" ]]; then
                echo "  ✓ $hook_label → $hook_val"
            else
                echo "  ⚠ $hook_label → $hook_val (file not found)"
                issues=$((issues + 1))
            fi
        else
            echo "  - $hook_label: not configured"
        fi
    done

    # Kamal check
    echo ""
    if command -v kamal &>/dev/null; then
        echo "✓ Kamal found: $(kamal version 2>/dev/null || echo 'installed')"
    else
        echo "⚠ Kamal not found on PATH"
        issues=$((issues + 1))
    fi

    echo ""
    if [[ $issues -eq 0 ]]; then
        echo "═══════════════════════════════════════"
        echo "  ✓ Config OK"
        echo "═══════════════════════════════════════"
    else
        echo "═══════════════════════════════════════"
        echo "  ⚠ $issues issue(s) found"
        echo "═══════════════════════════════════════"
    fi
}

# ==============================================================================
# STAGE
# ==============================================================================

cmd_stage() {
    load_config

    if ! yaml_section_exists "$CONFIG" "staging"; then
        echo "❌ Staging not configured in deploy-config.yml"
        exit 1
    fi

    if [[ -z "$SOURCE_BRANCH" ]]; then
        echo "❌ source.branch not set in deploy-config.yml"
        exit 1
    fi

    local check=false continue_stage=false
    for arg in "$@"; do
        case "$arg" in
            --check) check=true ;;
            --continue) continue_stage=true ;;
        esac
    done

    if [[ "$check" == true ]]; then
        stage_preflight
        return
    fi

    # Squash merges are not driven by this command: git merge --squash never
    # creates a commit, so a squash needs a hand-authored commit (and can't be
    # resumed via MERGE_HEAD after a conflict). Stage a squash manually with git.
    if [[ "$STAGING_MERGE_STRATEGY" == *"--squash"* ]]; then
        echo "❌ staging.merge_strategy uses --squash, which dev-deploy stage does not support"
        echo "   A squash needs a manual commit. Stage it by hand:"
        echo "     git switch $STAGING_BRANCH"
        echo "     git pull origin $STAGING_BRANCH"
        echo "     git merge --squash $SOURCE_BRANCH    # resolve any conflicts"
        echo "     git commit && git push origin $STAGING_BRANCH"
        exit 1
    fi

    # --- Continue after resolving conflicts ---
    # A conflicted merge leaves you on the staging branch mid-merge; you resolve,
    # then re-run with --continue to finish the merge commit and push. No state
    # is stashed — git's own MERGE_HEAD is the source of truth, and you stay on
    # staging afterwards (where the conflict left you).
    if [[ "$continue_stage" == true ]]; then
        require_merging

        echo "→ Completing merge of $SOURCE_BRANCH into $STAGING_BRANCH..."
        git commit --no-edit

        echo "→ Pushing $STAGING_BRANCH to origin..."
        git push origin "$STAGING_BRANCH"

        echo ""
        echo "═══════════════════════════════════════"
        echo "  ✓ Staged (now on $STAGING_BRANCH)"
        echo "═══════════════════════════════════════"
        echo ""
        echo "Next: dev-deploy deploy staging --check"
        return 0
    fi

    # --- Execute stage ---

    # Verify source is in sync with origin (fail fast)
    git fetch origin "$SOURCE_BRANCH" --quiet
    local local_head origin_head
    local_head=$(git rev-parse "$SOURCE_BRANCH" 2>/dev/null)
    origin_head=$(git rev-parse "origin/$SOURCE_BRANCH" 2>/dev/null || echo "")

    if [[ -n "$origin_head" && "$local_head" != "$origin_head" ]]; then
        echo "❌ $SOURCE_BRANCH is not in sync with origin"
        echo "   Run: dev-deploy stage --check   (see details)"
        exit 1
    fi

    local original_branch
    original_branch=$(git symbolic-ref --short HEAD 2>/dev/null || git rev-parse --short HEAD)

    echo "🚀 Staging: $SOURCE_BRANCH → $STAGING_BRANCH"
    echo ""

    # Switch to staging
    echo "→ Switching to $STAGING_BRANCH..."
    git switch "$STAGING_BRANCH"

    # Pull latest staging
    echo "→ Pulling latest $STAGING_BRANCH..."
    git pull origin "$STAGING_BRANCH" --quiet

    # Merge source
    echo "→ Merging $SOURCE_BRANCH..."
    # shellcheck disable=SC2086
    if ! git merge "$SOURCE_BRANCH" $STAGING_MERGE_STRATEGY; then
        echo ""
        echo "⚠ Merge conflicts on $STAGING_BRANCH — staging paused"
        echo "  1. Resolve the conflicts (git status)"
        echo "  2. Run: dev-deploy stage --continue"
        echo ""
        echo "  You are on $STAGING_BRANCH. --continue finishes the merge commit,"
        echo "  pushes, and leaves you here (it does not return to $original_branch)."
        exit 1
    fi

    # Push
    echo "→ Pushing $STAGING_BRANCH to origin..."
    git push origin "$STAGING_BRANCH"

    # Return to original branch
    echo "→ Returning to $original_branch..."
    git switch "$original_branch"

    echo ""
    echo "═══════════════════════════════════════"
    echo "  ✓ Staged"
    echo "═══════════════════════════════════════"
    echo ""
    echo "Next: dev-deploy deploy staging --check"
}

stage_preflight() {
    echo ""
    echo "🔍 Stage preflight"
    echo ""
    echo "  Source:   $SOURCE_BRANCH"
    echo "  Target:   $STAGING_BRANCH"
    echo "  Strategy: $STAGING_MERGE_STRATEGY"
    [[ -n "$STAGING_URL" ]] && echo "  URL:      $STAGING_URL"
    echo ""

    # --- Source sync with origin ---
    git fetch origin "$SOURCE_BRANCH" --quiet 2>/dev/null || true

    local local_head origin_head
    local_head=$(git rev-parse "$SOURCE_BRANCH" 2>/dev/null || echo "missing")
    origin_head=$(git rev-parse "origin/$SOURCE_BRANCH" 2>/dev/null || echo "missing")

    if [[ "$local_head" == "missing" ]]; then
        echo "❌ Source branch '$SOURCE_BRANCH' not found locally"
    elif [[ "$origin_head" == "missing" ]]; then
        echo "⚠ No origin/$SOURCE_BRANCH found (no remote tracking)"
    elif [[ "$local_head" == "$origin_head" ]]; then
        echo "✓ $SOURCE_BRANCH in sync with origin"
    elif git merge-base --is-ancestor "$local_head" "$origin_head" 2>/dev/null; then
        local behind
        behind=$(git rev-list "$local_head".."$origin_head" --count)
        echo "⚠ $SOURCE_BRANCH is $behind commit(s) behind origin — pull needed"
    elif git merge-base --is-ancestor "$origin_head" "$local_head" 2>/dev/null; then
        local ahead
        ahead=$(git rev-list "$origin_head".."$local_head" --count)
        echo "⚠ $SOURCE_BRANCH is $ahead commit(s) ahead of origin — push needed"
    else
        echo "❌ $SOURCE_BRANCH has diverged from origin — resolve before staging"
    fi

    # --- Staging merge status ---
    git fetch origin "$STAGING_BRANCH" --quiet 2>/dev/null || true
    echo ""

    local source_head staging_head
    source_head=$(git rev-parse "$SOURCE_BRANCH" 2>/dev/null || echo "missing")
    staging_head=$(git rev-parse "$STAGING_BRANCH" 2>/dev/null || echo "missing")

    if [[ "$staging_head" == "missing" ]]; then
        echo "⚠ Staging branch '$STAGING_BRANCH' not found"
    elif [[ "$source_head" == "missing" ]]; then
        echo "❌ Cannot check merge status — source branch missing"
    elif git merge-base --is-ancestor "$source_head" "$staging_head" 2>/dev/null; then
        echo "✓ $STAGING_BRANCH is up to date with $SOURCE_BRANCH"
    else
        local unmerged
        unmerged=$(git rev-list "$STAGING_BRANCH".."$SOURCE_BRANCH" --count 2>/dev/null)
        echo "→ $unmerged commit(s) to merge from $SOURCE_BRANCH"
        echo ""
        echo "Recent commits:"
        git log "$STAGING_BRANCH".."$SOURCE_BRANCH" --oneline --max-count=10
    fi
}

# ==============================================================================
# DEPLOY
# ==============================================================================

cmd_deploy() {
    local env="${1:-}"

    if [[ -z "$env" ]]; then
        cmd_help deploy
        return
    fi

    shift

    case "$env" in
        staging)
            deploy_staging "$@"
            ;;
        production)
            deploy_production "$@"
            ;;
        *)
            echo "❌ Unknown environment: $env"
            echo "   Usage: dev-deploy deploy [staging|production]"
            exit 1
            ;;
    esac
}

deploy_staging() {
    load_config

    if ! yaml_section_exists "$CONFIG" "staging"; then
        echo "❌ Staging not configured in deploy-config.yml"
        exit 1
    fi

    local check=false
    local refresh_db=false
    for arg in "$@"; do
        case "$arg" in
            --check) check=true ;;
            --refresh-db) refresh_db=true ;;
        esac
    done

    local kamal_dest_flag=""
    [[ -n "$STAGING_KAMAL_DEST" ]] && kamal_dest_flag="-d $STAGING_KAMAL_DEST"

    if [[ "$check" == true ]]; then
        echo "🔍 Deploy staging check"
        echo ""
        echo "  Branch:      $STAGING_BRANCH"
        echo "  Kamal:       kamal deploy $kamal_dest_flag"
        [[ -n "$STAGING_URL" ]] && echo "  URL:         $STAGING_URL"
        [[ "$refresh_db" == true ]] && echo "  Refresh DB:  yes (hook: ${HOOK_REFRESH_DB:-not configured})"
        echo ""

        # Show current commit on staging
        echo "→ Latest on $STAGING_BRANCH:"
        git log "$STAGING_BRANCH" --oneline --max-count=5
        return
    fi

    # --- Execute deploy ---

    echo "🚀 Deploying to staging"
    echo ""

    # Switch to staging branch
    echo "→ Switching to $STAGING_BRANCH..."
    git switch "$STAGING_BRANCH"

    echo "→ Pulling latest $STAGING_BRANCH..."
    git pull origin "$STAGING_BRANCH"

    # Refresh DB if requested
    if [[ "$refresh_db" == true ]]; then
        run_hook "refresh_db" "$HOOK_REFRESH_DB" "staging"
    fi

    # Pre-deploy hook
    run_hook "pre_deploy" "$HOOK_PRE_DEPLOY" "staging"

    # Deploy
    echo ""
    echo "→ Deploying via Kamal..."
    # shellcheck disable=SC2086
    kamal deploy $kamal_dest_flag

    # Post-deploy hook
    run_hook "post_deploy" "$HOOK_POST_DEPLOY" "staging"

    echo ""
    echo "═══════════════════════════════════════"
    echo "  ✓ Staging deployed"
    echo "═══════════════════════════════════════"
    [[ -n "$STAGING_URL" ]] && echo "  $STAGING_URL"
}

deploy_production() {
    load_config

    if ! yaml_section_exists "$CONFIG" "production"; then
        echo "❌ Production not configured in deploy-config.yml"
        exit 1
    fi

    local check=false
    for arg in "$@"; do
        case "$arg" in
            --check) check=true ;;
        esac
    done

    local kamal_dest_flag=""
    [[ -n "$PROD_KAMAL_DEST" ]] && kamal_dest_flag="-d $PROD_KAMAL_DEST"

    local promote_from="${PROD_PROMOTE_FROM:-$SOURCE_BRANCH}"

    if [[ "$check" == true ]]; then
        echo "🔍 Deploy production check"
        echo ""
        echo "  Promote from: $promote_from"
        echo "  Branch:       $PROD_BRANCH"
        echo "  Kamal:        kamal deploy $kamal_dest_flag"
        [[ -n "$PROD_URL" ]] && echo "  URL:          $PROD_URL"
        [[ -n "$HOOK_BACKUP_DB" ]] && echo "  Backup hook:  $HOOK_BACKUP_DB"
        echo ""

        # Show what would be merged
        git fetch origin "$PROD_BRANCH" --quiet 2>/dev/null || true
        local prod_head promote_head
        prod_head=$(git rev-parse "origin/$PROD_BRANCH" 2>/dev/null || git rev-parse "$PROD_BRANCH" 2>/dev/null)
        promote_head=$(git rev-parse "$promote_from" 2>/dev/null)

        if [[ "$prod_head" == "$promote_head" ]]; then
            echo "✓ $PROD_BRANCH is up to date with $promote_from"
        elif git merge-base --is-ancestor "$promote_head" "$prod_head" 2>/dev/null; then
            echo "✓ $promote_from already merged into $PROD_BRANCH"
        else
            local unmerged
            unmerged=$(git rev-list "$PROD_BRANCH".."$promote_from" --count 2>/dev/null)
            echo "→ $unmerged commit(s) to promote from $promote_from"
            echo ""
            echo "Recent commits:"
            git log "$PROD_BRANCH".."$promote_from" --oneline --max-count=10
        fi
        return
    fi

    # --- Execute production deploy ---

    echo "🚀 Deploying to production"
    echo ""

    # Pull promote_from branch
    echo "→ Pulling latest $promote_from..."
    git switch "$promote_from"
    git pull origin "$promote_from"

    # Switch to production branch and merge
    echo "→ Switching to $PROD_BRANCH..."
    git switch "$PROD_BRANCH"
    git pull origin "$PROD_BRANCH"

    echo "→ Merging $promote_from into $PROD_BRANCH..."
    # shellcheck disable=SC2086
    git merge "$promote_from" $PROD_MERGE_STRATEGY

    echo "→ Pushing $PROD_BRANCH..."
    git push origin "$PROD_BRANCH"

    # Backup hook (before deploy)
    run_hook "backup_db" "$HOOK_BACKUP_DB" "production"

    # Pre-deploy hook
    run_hook "pre_deploy" "$HOOK_PRE_DEPLOY" "production"

    # Deploy
    echo ""
    echo "→ Deploying via Kamal..."
    # shellcheck disable=SC2086
    kamal deploy $kamal_dest_flag

    # Post-deploy hook
    run_hook "post_deploy" "$HOOK_POST_DEPLOY" "production"

    # Switch back to promote_from branch
    echo "→ Switching back to $promote_from..."
    git switch "$promote_from"

    echo ""
    echo "═══════════════════════════════════════"
    echo "  ✓ Production deployed"
    echo "═══════════════════════════════════════"
    [[ -n "$PROD_URL" ]] && echo "  $PROD_URL"
}

# ==============================================================================
# BOOT / STOP
# ==============================================================================

cmd_boot() {
    load_config

    local env="${1:-production}"
    local kamal_dest_flag=""

    case "$env" in
        staging)
            [[ -n "$STAGING_KAMAL_DEST" ]] && kamal_dest_flag="-d $STAGING_KAMAL_DEST"
            ;;
        production)
            [[ -n "$PROD_KAMAL_DEST" ]] && kamal_dest_flag="-d $PROD_KAMAL_DEST"
            ;;
        *)
            cmd_help boot; return
            ;;
    esac

    echo "🟢 Booting $env..."
    echo ""
    # shellcheck disable=SC2086
    kamal app boot $kamal_dest_flag

    echo ""
    echo "✓ $env application started"
}

cmd_stop() {
    load_config

    local env="${1:-production}"
    local kamal_dest_flag=""

    case "$env" in
        staging)
            [[ -n "$STAGING_KAMAL_DEST" ]] && kamal_dest_flag="-d $STAGING_KAMAL_DEST"
            ;;
        production)
            [[ -n "$PROD_KAMAL_DEST" ]] && kamal_dest_flag="-d $PROD_KAMAL_DEST"
            ;;
        *)
            cmd_help stop; return
            ;;
    esac

    echo "🔴 Stopping $env..."
    echo ""
    # shellcheck disable=SC2086
    kamal app stop $kamal_dest_flag

    echo ""
    echo "✓ $env application stopped"
}

# ==============================================================================
# SETUP
# ==============================================================================

cmd_setup() {
    load_config

    local check=false
    local refresh_db=false

    for arg in "$@"; do
        case "$arg" in
            --check) check=true ;;
            --refresh-db) refresh_db=true ;;
        esac
    done

    if [[ "$check" == true ]]; then
        echo "🔍 Setup check"
        echo ""
        echo "  Server:     ${SERVER_HOST:-not configured}"
        echo "  Refresh DB: hook=${HOOK_REFRESH_DB:-not configured}"
        return
    fi

    if [[ "$refresh_db" == true ]]; then
        if [[ -z "$HOOK_REFRESH_DB" ]]; then
            echo "❌ hooks.refresh_db not configured in deploy-config.yml"
            echo "   Run: dev-deploy init --hooks  (for example hook scripts)"
            exit 1
        fi
        run_hook "refresh_db" "$HOOK_REFRESH_DB" "staging"
        echo ""
        echo "✓ Staging database refreshed"
    else
        echo "Usage: dev-deploy setup --refresh-db"
        echo "  Run: dev-deploy help setup  (for full options)"
    fi
}

# ==============================================================================
# HEALTH
# ==============================================================================

cmd_health() {
    load_config

    echo ""
    echo "── Health Check ──"

    # --- Apps ---
    echo ""
    echo "Apps"
    echo ""

    if command -v kamal &>/dev/null; then
        if [[ -n "$PROD_KAMAL_DEST" ]]; then
            local prod_dest="-d $PROD_KAMAL_DEST"
        else
            local prod_dest=""
        fi

        echo -n "→ Production: "
        # shellcheck disable=SC2086
        local prod_status
        prod_status=$(kamal app details -q $prod_dest 2>/dev/null | sed -n 's/.*Up \([0-9]* [a-z]*\).*/\1/p' | head -1)
        if [[ -n "$prod_status" ]]; then
            echo "up ($prod_status)"
        else
            echo "down"
        fi

        if yaml_section_exists "$CONFIG" "staging" && [[ -n "$STAGING_KAMAL_DEST" ]]; then
            echo -n "→ Staging:    "
            local staging_status
            staging_status=$(kamal app details -q -d "$STAGING_KAMAL_DEST" 2>/dev/null | sed -n 's/.*Up \([0-9]* [a-z]*\).*/\1/p' | head -1)
            if [[ -n "$staging_status" ]]; then
                echo "up ($staging_status)"
            else
                echo "stopped"
            fi
        fi
    else
        echo "  Kamal not found — skipping app checks"
    fi

    # --- Branches ---
    echo ""
    echo "Branches"
    echo ""

    # Source sync with origin
    if [[ -n "$SOURCE_BRANCH" ]]; then
        git fetch origin "$SOURCE_BRANCH" --quiet 2>/dev/null || true
        echo -n "→ $SOURCE_BRANCH: "
        local local_head origin_head
        local_head=$(git rev-parse "$SOURCE_BRANCH" 2>/dev/null || echo "missing")
        origin_head=$(git rev-parse "origin/$SOURCE_BRANCH" 2>/dev/null || echo "missing")

        if [[ "$local_head" == "missing" ]]; then
            echo "not found locally"
        elif [[ "$origin_head" == "missing" ]]; then
            echo "no origin tracking"
        elif [[ "$local_head" == "$origin_head" ]]; then
            echo "in sync with origin"
        else
            echo "not in sync with origin"
        fi
    fi

    # Staging sync with origin
    if [[ -n "$STAGING_BRANCH" ]]; then
        git fetch origin "$STAGING_BRANCH" --quiet 2>/dev/null || true
        echo -n "→ $STAGING_BRANCH: "
        local ahead behind
        ahead=$(git rev-list "origin/$STAGING_BRANCH".."$STAGING_BRANCH" --count 2>/dev/null || echo "?")
        behind=$(git rev-list "$STAGING_BRANCH".."origin/$STAGING_BRANCH" --count 2>/dev/null || echo "?")
        if [[ "$ahead" -eq 0 && "$behind" -eq 0 ]]; then
            echo "in sync with origin"
        else
            local status=""
            [[ "$ahead" -gt 0 ]] && status="${ahead} ahead"
            [[ "$behind" -gt 0 ]] && status="${status:+$status, }${behind} behind"
            echo "$status"
        fi

        # Source → staging merge status
        if [[ -n "$SOURCE_BRANCH" ]]; then
            local source_head staging_head
            source_head=$(git rev-parse "$SOURCE_BRANCH" 2>/dev/null || echo "missing")
            staging_head=$(git rev-parse "$STAGING_BRANCH" 2>/dev/null || echo "missing")
            echo -n "→ $SOURCE_BRANCH → $STAGING_BRANCH: "
            if [[ "$source_head" == "missing" || "$staging_head" == "missing" ]]; then
                echo "cannot determine"
            elif git merge-base --is-ancestor "$source_head" "$staging_head" 2>/dev/null; then
                echo "up to date"
            else
                local unmerged
                unmerged=$(git rev-list "$STAGING_BRANCH".."$SOURCE_BRANCH" --count 2>/dev/null)
                echo "${unmerged} commit(s) not yet staged"
            fi
        fi
    fi

    # --- Server health hook ---
    if [[ -n "$HOOK_HEALTH" ]]; then
        run_hook "health" "$HOOK_HEALTH" ""
    elif [[ -n "$SERVER_HOST" ]]; then
        # Basic server checks if no custom hook
        echo ""
        echo "Server ($SERVER_HOST)"
        echo ""

        echo "→ Disk:"
        ssh -p "$SERVER_PORT" -o ConnectTimeout=5 "$SERVER_HOST" \
            "df -h / | tail -1 | awk '{printf \"  %s used of %s (%s free)\n\", \$3, \$2, \$4}'" \
            2>/dev/null || echo "  connection failed"
    fi

    echo ""
}

# ==============================================================================
# DISPATCH
# ==============================================================================

COMMAND="${1:-help}"
shift 2>/dev/null || true

# Intercept help requests: dev-deploy <command> --help
for arg in "$@"; do
    if [[ "$arg" == "--help" || "$arg" == "-h" ]]; then
        cmd_help "$COMMAND"
        exit 0
    fi
done

case "$COMMAND" in
    init)       cmd_init "$@" ;;
    stage)      cmd_stage "$@" ;;
    deploy)     cmd_deploy "$@" ;;
    boot)       cmd_boot "$@" ;;
    stop)       cmd_stop "$@" ;;
    setup)      cmd_setup "$@" ;;
    health)     cmd_health "$@" ;;
    help|--help|-h) cmd_help "$@" ;;
    version|--version|-v) echo "dev-deploy v${VERSION}" ;;
    *)
        echo "❌ Unknown command: $COMMAND"
        echo "   Run: dev-deploy help"
        exit 1
        ;;
esac
