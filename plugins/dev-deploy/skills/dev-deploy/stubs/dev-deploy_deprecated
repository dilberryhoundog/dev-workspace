#!/bin/bash
# Finds and runs the project-local dev-deploy skill script.
SCRIPT_PATH=".claude/skills/dev-deploy/scripts/dev-deploy"

dir="$PWD"
while [[ "$dir" != "/" ]]; do
    if [[ -f "$dir/$SCRIPT_PATH" ]]; then
        exec "$dir/$SCRIPT_PATH" "$@"
    fi
    dir="$(dirname "$dir")"
done
echo "❌ dev-deploy skill not found — install it in your project to use deploy commands"
exit 1
